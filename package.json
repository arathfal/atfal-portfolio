{
  "name": "atfal-portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.13.1",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "pnpm prisma:generate:prod && next build",
    "build:local": "pnpm prisma:generate && next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "seed": "tsx prisma/seed.ts",
    "prisma:generate": "prisma generate --schema prisma/sqlite/schema.prisma",
    "prisma:generate:prod": "prisma generate --schema prisma/postgresql/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema prisma/sqlite/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema prisma/postgresql/schema.prisma",
    "prisma:validate": "prisma validate --schema prisma/sqlite/schema.prisma && prisma validate --schema prisma/postgresql/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "next": "15.5.19",
    "next-themes": "^0.4.6",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "15.5.19",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.19.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
